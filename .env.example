# Google OAuth credentials — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret used to sign session tokens (use a long random string in production)
SESSION_SECRET=

# Comma-separated list of Google account emails that have server-admin privileges
SERVER_ADMIN_EMAILS=

# OAuth callback URL — must exactly match an Authorized Redirect URI in Google Cloud Console.
# Set this to your CF tunnel domain: https://yourdomain.com/api/auth/callback
AUTH_REDIRECT_URL=https://yourdomain.com/api/auth/callback
